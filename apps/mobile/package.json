{
  "name": "otnal-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "check": "tsc --noEmit",
    "proxy:search": "node scripts/product-search-proxy.mjs",
    "server:bootstrap": "zsh scripts/bootstrap-mac-mini-server.sh",
    "server:install": "zsh scripts/install-product-search-launch-agent.sh",
    "server:status": "zsh scripts/status-product-search-launch-agent.sh",
    "server:sync": "zsh scripts/sync-and-restart-server.sh",
    "server:uninstall": "zsh scripts/uninstall-product-search-launch-agent.sh",
    "release:check": "node scripts/check-release-readiness.mjs",
    "release:ios:build": "eas build --platform ios --profile production",
    "release:ios:submit": "eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/ibm-plex-sans-kr": "^0.4.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~54.0.33",
    "expo-font": "~14.0.11",
    "expo-location": "~19.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
