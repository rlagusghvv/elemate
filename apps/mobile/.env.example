# App client setting. TestFlight/App Store builds must use HTTPS.
EXPO_PUBLIC_PRODUCT_SEARCH_BASE_URL=https://api.your-domain.example

# Server-only settings for scripts/product-search-proxy.mjs.
# Do not ship these values in the app bundle.
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
PORT=8787
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
